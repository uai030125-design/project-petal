{
  "name": "unlimited-avenues",
  "version": "1.0.0",
  "description": "Unlimited Avenues Operations Dashboard",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && node index.js",
    "client": "cd client && npm start",
    "start": "cd server && node index.js",
    "build": "cd client && npm install && npm run build",
    "db:migrate": "cd server && node migrations/run.js",
    "db:seed": "cd server && node seeds/run.js",
    "db:reset": "npm run db:migrate && npm run db:seed",
    "setup": "npm install && cd client && npm install && cd .. && npm run db:reset"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.12.0",
    "xlsx": "^0.18.5"
  }
}
